@using Microsoft.AspNetCore.Mvc.Rendering
@{
    ViewData["Title"] = "Assign Course";
}

<h2>Assign Course to @ViewBag.FacultyName</h2>

<form asp-action="AssignCourse" asp-route-id="@ViewBag.FacultyId" method="post">
    @Html.AntiForgeryToken()
    <div class="mb-3">
        <label class="form-label">Course</label>
        <select name="courseId" class="form-select">
            <option value="">-- Select Course --</option>
            @foreach (SelectListItem item in ViewBag.Courses)
            {
                <option value="@item.Value">@item.Text</option>
            }
        </select>
    </div>
    <button type="submit" class="btn btn-primary">Assign</button>
    <a asp-action="Details" asp-route-id="@ViewBag.FacultyId" class="btn btn-secondary">Cancel</a>
</form>