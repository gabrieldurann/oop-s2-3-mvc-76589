@model IEnumerable<VgcCollege.Web.Models.Assignment>
@{
    var course = (VgcCollege.Web.Models.Course)ViewBag.Course;
    ViewData["Title"] = "Gradebook — " + course.Name;
}

<h2>Gradebook — @course.Name</h2>
<p>Branch: @course.Branch.Name</p>

@if (Model.Any())
{
    @foreach (var assignment in Model)
    {
        <div class="card mb-3">
            <div class="card-header d-flex justify-content-between align-items-center">
                <strong>@assignment.Title</strong>
                <span>Max Score: @assignment.MaxScore | Due: @assignment.DueDate.ToString("dd/MM/yyyy")</span>
            </div>
            <div class="card-body">
                @if (assignment.Results.Any())
                {
                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th>Student</th>
                                <th>Score</th>
                                <th>Feedback</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var r in assignment.Results)
                            {
                                <tr>
                                    <td>@r.StudentProfile.Name</td>
                                    <td>@r.Score / @assignment.MaxScore</td>
                                    <td>@(r.Feedback ?? "—")</td>
                                    <td>
                                        <a asp-action="EditResult" asp-route-id="@r.Id" class="btn btn-sm btn-warning">Edit</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p class="text-muted">No results entered yet.</p>
                }
                <a asp-action="EnterResult" asp-route-id="@assignment.Id" class="btn btn-sm btn-success">Enter Result</a>
            </div>
        </div>
    }
}
else
{
    <p class="text-muted">No assignments for this course yet.</p>
}

<a asp-controller="FacultyDashboard" asp-action="Index" class="btn btn-secondary">Back to Dashboard</a>