@model VgcCollege.Web.Models.AssignmentResult
@{
    ViewData["Title"] = "Edit Result";
}

<h2>Edit Result</h2>
<p><strong>Assignment:</strong> @Model.Assignment.Title | <strong>Student:</strong> @Model.StudentProfile.Name | <strong>Max Score:</strong> @Model.Assignment.MaxScore</p>

<form asp-action="EditResult" asp-route-id="@Model.Id" method="post">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="All" class="text-danger"></div>
    <div class="mb-3">
        <label class="form-label">Score (0 — @Model.Assignment.MaxScore)</label>
        <input name="score" type="number" min="0" max="@Model.Assignment.MaxScore" class="form-control" value="@Model.Score" />
    </div>
    <div class="mb-3">
        <label class="form-label">Feedback</label>
        <textarea name="feedback" class="form-control" rows="3">@Model.Feedback</textarea>
    </div>
    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Course" asp-route-id="@Model.Assignment.CourseId" class="btn btn-secondary">Cancel</a>
</form>