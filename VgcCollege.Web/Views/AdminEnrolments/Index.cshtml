@model IEnumerable<VgcCollege.Web.Models.CourseEnrolment>
@{
    ViewData["Title"] = "Enrolments";
}

<h2>Enrolments</h2>
<p><a asp-action="Create" class="btn btn-primary">New Enrolment</a></p>

<table class="table table-striped">
    <thead>
    <tr>
        <th>Student</th>
        <th>Student Number</th>
        <th>Course</th>
        <th>Branch</th>
        <th>Enrol Date</th>
        <th>Status</th>
        <th>Actions</th>
    </tr>
    </thead>
    <tbody>
    @foreach (var e in Model)
    {
        <tr>
            <td>@e.StudentProfile.Name</td>
            <td>@e.StudentProfile.StudentNumber</td>
            <td>@e.Course.Name</td>
            <td>@e.Course.Branch.Name</td>
            <td>@e.EnrolDate.ToString("dd/MM/yyyy")</td>
            <td>
                <span class="badge @(e.Status == "Active" ? "bg-success" : e.Status == "Completed" ? "bg-primary" : "bg-secondary")">
                    @e.Status
                </span>
            </td>
            <td>
                <a asp-action="Details" asp-route-id="@e.Id" class="btn btn-sm btn-info">Details</a>
                <a asp-action="Edit" asp-route-id="@e.Id" class="btn btn-sm btn-warning">Edit Status</a>
                <a asp-action="Delete" asp-route-id="@e.Id" class="btn btn-sm btn-danger">Delete</a>
            </td>
        </tr>
    }
    </tbody>
</table>