@model VgcCollege.Web.Models.CourseEnrolment
@{
    ViewData["Title"] = "Enrolment Details";
    var attendanceRecords = (List<AttendanceRecord>)ViewBag.AttendanceRecords;
    var assignmentResults = (List<AssignmentResult>)ViewBag.AssignmentResults;
    var examResults = (List<ExamResult>)ViewBag.ExamResults;
}

<h2>Enrolment Details</h2>

<dl class="row">
    <dt class="col-sm-3">Student</dt>
    <dd class="col-sm-9">@Model.StudentProfile.Name (@Model.StudentProfile.StudentNumber)</dd>
    <dt class="col-sm-3">Course</dt>
    <dd class="col-sm-9">@Model.Course.Name</dd>
    <dt class="col-sm-3">Branch</dt>
    <dd class="col-sm-9">@Model.Course.Branch.Name</dd>
    <dt class="col-sm-3">Enrol Date</dt>
    <dd class="col-sm-9">@Model.EnrolDate.ToString("dd/MM/yyyy")</dd>
    <dt class="col-sm-3">Status</dt>
    <dd class="col-sm-9">
        <span class="badge @(Model.Status == "Active" ? "bg-success" : Model.Status == "Completed" ? "bg-primary" : "bg-secondary")">
            @Model.Status
        </span>
    </dd>
</dl>

<h4>Attendance</h4>
@if (attendanceRecords.Any())
{
    var totalSessions = attendanceRecords.Count;
    var presentCount = attendanceRecords.Count(a => a.Present);
    <p>Attendance rate: <strong>@presentCount / @totalSessions (@(totalSessions > 0 ? (presentCount * 100 / totalSessions) : 0)%)</strong></p>
    <table class="table table-sm">
        <thead>
            <tr>
                <th>Date</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var a in attendanceRecords)
            {
                <tr>
                    <td>@a.Date.ToString("dd/MM/yyyy")</td>
                    <td>
                        @if (a.Present)
                        {
                            <span class="badge bg-success">Present</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Absent</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p class="text-muted">No attendance records yet.</p>
}

<h4>Assignment Results</h4>
@if (assignmentResults.Any())
{
    <table class="table table-sm">
        <thead>
            <tr>
                <th>Assignment</th>
                <th>Score</th>
                <th>Max Score</th>
                <th>Feedback</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var ar in assignmentResults)
            {
                <tr>
                    <td>@ar.Assignment.Title</td>
                    <td>@ar.Score</td>
                    <td>@ar.Assignment.MaxScore</td>
                    <td>@(ar.Feedback ?? "—")</td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p class="text-muted">No assignment results yet.</p>
}

<h4>Exam Results</h4>
@if (examResults.Any())
{
    <table class="table table-sm">
        <thead>
            <tr>
                <th>Exam</th>
                <th>Score</th>
                <th>Max Score</th>
                <th>Grade</th>
                <th>Released</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var er in examResults)
            {
                <tr>
                    <td>@er.Exam.Title</td>
                    <td>@er.Score</td>
                    <td>@er.Exam.MaxScore</td>
                    <td>@(er.Grade ?? "—")</td>
                    <td>
                        @if (er.Exam.ResultsReleased)
                        {
                            <span class="badge bg-success">Released</span>
                        }
                        else
                        {
                            <span class="badge bg-warning">Provisional</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p class="text-muted">No exam results yet.</p>
}

<a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit Status</a>
<a asp-action="Index" class="btn btn-secondary">Back to List</a>