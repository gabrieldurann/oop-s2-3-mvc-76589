@model VgcCollege.Web.Models.CourseEnrolment
@using Microsoft.AspNetCore.Mvc.Rendering
@{
    ViewData["Title"] = "New Enrolment";
}

<h2>New Enrolment</h2>

<form asp-action="Create" method="post">
    <div asp-validation-summary="All" class="text-danger"></div>
    <div class="mb-3">
        <label class="form-label">Student</label>
        <select asp-for="StudentProfileId" class="form-select">
            <option value="">-- Select Student --</option>
            @foreach (SelectListItem item in ViewBag.Students)
            {
                <option value="@item.Value">@item.Text</option>
            }
        </select>
        <span asp-validation-for="StudentProfileId" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label class="form-label">Course</label>
        <select asp-for="CourseId" class="form-select">
            <option value="">-- Select Course --</option>
            @foreach (SelectListItem item in ViewBag.Courses)
            {
                <option value="@item.Value">@item.Text</option>
            }
        </select>
        <span asp-validation-for="CourseId" class="text-danger"></span>
    </div>
    <button type="submit" class="btn btn-primary">Enrol</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>