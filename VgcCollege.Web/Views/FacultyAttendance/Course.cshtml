@model IEnumerable<VgcCollege.Web.Models.CourseEnrolment>
@{
    var course = (VgcCollege.Web.Models.Course)ViewBag.Course;
    ViewData["Title"] = "Attendance — " + course.Name;
}

<h2>Attendance — @course.Name</h2>
<p>Branch: @course.Branch.Name</p>

<a asp-action="MarkAttendance" asp-route-id="@course.Id" class="btn btn-success mb-3">Mark Attendance</a>

@if (Model.Any())
{
    <table class="table table-striped">
        <thead>
        <tr>
            <th>Student</th>
            <th>Student Number</th>
            <th>Status</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var e in Model)
        {
            <tr>
                <td>@e.StudentProfile.Name</td>
                <td>@e.StudentProfile.StudentNumber</td>
                <td>
                    <span class="badge bg-success">Active</span>
                </td>
            </tr>
        }
        </tbody>
    </table>
}
else
{
    <p class="text-muted">No active students in this course.</p>
}

<a asp-action="Index" class="btn btn-secondary">Back to Courses</a>